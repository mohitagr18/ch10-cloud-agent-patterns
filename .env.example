# =============================================================================
# Chapter 10 — Cloud Agent Patterns
# Environment configuration template
#
# Copy this file to .env and fill in every value before running any script.
#   cp .env.example .env
#
# NEVER commit .env to version control. It is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# GCP project identity
# Your Google Cloud project ID (not the display name, not the number).
# Example: my-company-dev-123456
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=YOUR_PROJECT_ID

# The GCP region where your Vertex AI RAG corpus and Cloud Run services live.
# All resources should be in the same region to avoid cross-region latency.
# Example: us-central1
GOOGLE_CLOUD_LOCATION=us-central1

# -----------------------------------------------------------------------------
# Credentials (local development only)
# Path to a GCP service account JSON key file on your local machine.
# This file must belong to a service account with the IAM roles listed in
# the README under "Required IAM roles".
#
# Cloud Run services do NOT use this variable — they use the service account
# attached to the Cloud Run revision at deploy time.
#
# Example: /home/you/.config/gcloud/sa-key.json
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# -----------------------------------------------------------------------------
# Vertex AI RAG corpus
# The full resource name of your RAG corpus. You create this corpus once,
# ingest your documents into it, and then point all services at it.
#
# Format: projects/PROJECT_ID/locations/REGION/ragCorpora/CORPUS_NUMERIC_ID
# Example: projects/my-project/locations/us-central1/ragCorpora/1234567890123456789
#
# To list your corpora:
#   gcloud ai rag-corpora list --project=YOUR_PROJECT_ID --region=us-central1
# -----------------------------------------------------------------------------
RAG_CORPUS=projects/YOUR_PROJECT_ID/locations/us-central1/ragCorpora/YOUR_CORPUS_ID

# -----------------------------------------------------------------------------
# Cloud Run service URLs (populated after deployment)
# Leave these empty until you have deployed both services in Milestone F.
# The validate_services.py script uses these to run the end-to-end health check.
#
# RETRIEVAL_SERVICE_URL — the deployed URL of Service A (FastAPI retrieval service)
# Example: https://policy-retrieval-abc123-uc.a.run.app
# -----------------------------------------------------------------------------
RETRIEVAL_SERVICE_URL=

# AGENT_SERVICE_URL — the deployed URL of Service B (ADK agent backend)
# Example: https://policy-agent-abc123-uc.a.run.app
AGENT_SERVICE_URL=

# -----------------------------------------------------------------------------
# Agent configuration
# The Gemini model used by the ADK agent in both the broken and fixed versions.
# Example: gemini-2.0-flash-001
# -----------------------------------------------------------------------------
AGENT_MODEL=gemini-2.0-flash-001
